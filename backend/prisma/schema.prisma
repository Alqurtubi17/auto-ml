datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-python"
  interface            = "asyncio"
  recursive_type_depth = 5
}

model MLProject {
  id             String    @id @default(uuid())
  projectName    String
  taskType       String    // "classification", "regression", "clustering"
  status         String    // "queued", "training", "done", "error"
  progress       Int       @default(0)
  accuracy       Float?
  huggingFaceUrl String?
  generatedCode  String?   @db.Text
  uiSchema       Json?     // Menyimpan struktur form input untuk dashboard
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  logs           String[]
}